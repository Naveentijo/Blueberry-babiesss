# CampusFlow Server Environment Variables
# Copy this file to .env and fill in real values

PORT=5000

# Supabase
SUPABASE_URL=https://your_supabase_project_id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Groq AI — get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# n8n Webhooks — paste your n8n webhook URLs here
N8N_TASK_WEBHOOK=https://your-n8n-instance.com/webhook/campusflow-task
N8N_NOTICE_WEBHOOK=https://your-n8n-instance.com/webhook/campusflow-notice

# JWT
JWT_SECRET=campusflow_super_secret_jwt_key_change_this_in_production_2026

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173
